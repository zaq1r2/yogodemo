---
import site from '../../content/site.json';
const base = import.meta.env.BASE_URL;
---

<footer class="bg-brand-900 text-brand-100">
  <!-- Newsletter -->
  <div class="border-b border-brand-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 text-center">
      <h3 class="text-2xl font-serif font-bold text-white mb-3">Stay Connected</h3>
      <p class="text-brand-200 mb-6 max-w-lg mx-auto">
        Join Christine's newsletter for class updates, wellness tips, and community news.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          placeholder="Your email address"
          class="flex-1 px-4 py-3 rounded-full bg-brand-800 border border-brand-600 text-white placeholder-brand-400 focus:outline-none focus:ring-2 focus:ring-sage-400"
          disabled
          aria-label="Email address (placeholder)"
        />
        <button
          class="px-6 py-3 bg-sage-600 hover:bg-sage-700 text-white font-semibold rounded-full transition-colors"
          disabled
        >
          Subscribe
        </button>
      </div>
      <p class="text-brand-400 text-xs mt-3">Newsletter signup coming soon</p>
    </div>
  </div>

  <!-- Links -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand -->
      <div>
        <h4 class="text-lg font-serif font-bold text-white mb-4">{site.name}</h4>
        <p class="text-brand-300 text-sm leading-relaxed">{site.tagline}</p>
        <div class="flex gap-4 mt-4">
          {site.socials.instagram && (
            <a href={site.socials.instagram} class="text-brand-300 hover:text-white transition-colors" aria-label="Instagram" target="_blank" rel="noopener">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          )}
          {site.socials.facebook && (
            <a href={site.socials.facebook} class="text-brand-300 hover:text-white transition-colors" aria-label="Facebook" target="_blank" rel="noopener">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          )}
          {site.socials.youtube && (
            <a href={site.socials.youtube} class="text-brand-300 hover:text-white transition-colors" aria-label="YouTube" target="_blank" rel="noopener">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
          )}
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Quick Links</h4>
        <ul class="space-y-2 text-sm">
          <li><a href={`${base}version-a/work-with-christine/`} class="text-brand-300 hover:text-white transition-colors">Work with Christine</a></li>
          <li><a href={`${base}version-a/programs/`} class="text-brand-300 hover:text-white transition-colors">Programs</a></li>
          <li><a href={`${base}version-a/events/`} class="text-brand-300 hover:text-white transition-colors">Events</a></li>
          <li><a href={`${base}version-a/books-press/`} class="text-brand-300 hover:text-white transition-colors">Books & Press</a></li>
        </ul>
      </div>

      <!-- More -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">More</h4>
        <ul class="space-y-2 text-sm">
          <li><a href={`${base}version-a/about/`} class="text-brand-300 hover:text-white transition-colors">About Christine</a></li>
          <li><a href={`${base}version-a/liberation-yoga/`} class="text-brand-300 hover:text-white transition-colors">Liberation Yoga Legacy</a></li>
          <li><a href={`${base}version-a/contact/`} class="text-brand-300 hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Get in Touch</h4>
        <p class="text-sm text-brand-300">
          <a href={`mailto:${site.email}`} class="hover:text-white transition-colors">{site.email}</a>
        </p>
        <p class="text-sm text-brand-400 mt-2">Los Angeles, California</p>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-brand-700 text-center text-sm text-brand-400">
      <p>&copy; {new Date().getFullYear()} {site.name}. All rights reserved.</p>
    </div>
  </div>
</footer>
