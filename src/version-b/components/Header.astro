---
import site from '../../content/site.json';
const base = import.meta.env.BASE_URL;
const vb = `${base}version-b/`;

const navLinks = [
  { label: 'Work with Christine', href: `${vb}work-with-christine/` },
  { label: 'Programs', href: `${vb}programs/` },
  { label: 'Events', href: `${vb}events/` },
  { label: 'Books & Press', href: `${vb}books-press/` },
  { label: 'About', href: `${vb}about/` },
  { label: 'Contact', href: `${vb}contact/` },
];
---

<!-- Grá-style: vertical stacked nav, top-left, ALL CAPS -->
<header class="fixed top-0 left-0 z-50 p-6 lg:p-10">
  <nav aria-label="Main navigation">
    <!-- Desktop: stacked vertical links -->
    <div class="hidden md:flex flex-col items-start">
      {navLinks.map((link) => (
        <a href={link.href} class="nav-link hover-underline leading-relaxed">
          {link.label}
        </a>
      ))}
    </div>

    <!-- Mobile: toggle -->
    <div class="md:hidden">
      <button
        id="vb-menu-btn"
        class="nav-link hover-underline"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        Menu
      </button>
      <div id="vb-mobile-menu" class="hidden mt-4">
        <div class="flex flex-col items-start">
          {navLinks.map((link) => (
            <a href={link.href} class="nav-link hover-underline leading-relaxed">
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('vb-menu-btn');
  const menu = document.getElementById('vb-mobile-menu');
  btn?.addEventListener('click', () => {
    const open = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!open));
    btn.textContent = open ? 'Close' : 'Menu';
    menu?.classList.toggle('hidden');
  });
</script>
