---
import site from '../../content/site.json';
const base = import.meta.env.BASE_URL;
const vb = `${base}version-b/`;

const navLinks = [
  { label: 'Work with Christine', href: `${vb}work-with-christine/` },
  { label: 'Programs', href: `${vb}programs/` },
  { label: 'Events', href: `${vb}events/` },
  { label: 'Books & Press', href: `${vb}books-press/` },
  { label: 'About', href: `${vb}about/` },
  { label: 'Contact', href: `${vb}contact/` },
];
---

<!-- Grá-style: vertical stacked nav, always visible at all sizes -->
<header class="fixed top-0 left-0 z-50 p-6 lg:p-10">
  <nav aria-label="Main navigation">
    <div class="flex flex-col items-start">
      {navLinks.map((link) => (
        <a href={link.href} class="nav-link hover-underline leading-relaxed">
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>
