---
import site from '../../content/site.json';
const base = import.meta.env.BASE_URL;
const vb = `${base}version-b/`;
---

<footer class="mt-auto container-wide pb-10 pt-space-5">
  <div class="max-w-3xl">
    <div class="flex flex-col gap-1 mb-space-4">
      <a href={`${vb}work-with-christine/`} class="nav-link hover-underline">Work with Christine</a>
      <a href={`${vb}programs/`} class="nav-link hover-underline">Programs</a>
      <a href={`${vb}events/`} class="nav-link hover-underline">Events</a>
      <a href={`${vb}books-press/`} class="nav-link hover-underline">Books & Press</a>
      <a href={`${vb}about/`} class="nav-link hover-underline">About</a>
      <a href={`${vb}liberation-yoga/`} class="nav-link hover-underline">Liberation Yoga Legacy</a>
      <a href={`${vb}contact/`} class="nav-link hover-underline">Contact</a>
    </div>

    <div class="flex flex-col sm:flex-row sm:items-center gap-3 text-xs text-muted">
      <p>&copy; {new Date().getFullYear()} {site.name}</p>
      <span class="hidden sm:inline">&middot;</span>
      <div class="flex gap-4">
        {site.socials.instagram && <a href={site.socials.instagram} class="hover-underline" target="_blank" rel="noopener">Instagram</a>}
        {site.socials.facebook && <a href={site.socials.facebook} class="hover-underline" target="_blank" rel="noopener">Facebook</a>}
        {site.socials.youtube && <a href={site.socials.youtube} class="hover-underline" target="_blank" rel="noopener">YouTube</a>}
      </div>
    </div>
  </div>
</footer>
