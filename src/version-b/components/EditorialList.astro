---
/**
 * Menu-style editorial list.
 * Items: { title, meta, description?, href? }
 */
interface Item {
  title: string;
  meta: string;
  description?: string;
  href?: string;
}
interface Props {
  items: Item[];
}
const { items } = Astro.props;
---

<div class="divide-y divide-border">
  {items.map((item) => (
    <div class="py-5 first:pt-0">
      <div class="flex flex-col sm:flex-row sm:items-baseline justify-between gap-1">
        {item.href ? (
          <a href={item.href} class="font-medium hover-underline">{item.title}</a>
        ) : (
          <span class="font-medium">{item.title}</span>
        )}
        <span class="text-sm text-muted whitespace-nowrap">{item.meta}</span>
      </div>
      {item.description && (
        <p class="text-sm text-muted mt-1.5 max-w-[55ch]">{item.description}</p>
      )}
    </div>
  ))}
</div>
