---
import site from '../content/site.json';
const base = import.meta.env.BASE_URL;

const navLinks = [
  { label: 'Home', href: `${base}` },
  { label: 'Work with Christine', href: `${base}work-with-christine/` },
  { label: 'Programs', href: `${base}programs/` },
  { label: 'Events', href: `${base}events/` },
  { label: 'Books & Press', href: `${base}books-press/` },
  { label: 'About', href: `${base}about/` },
];
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-brand-100 shadow-sm">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href={`${base}`} class="flex items-center gap-2 group">
        <span class="text-xl lg:text-2xl font-serif font-bold text-brand-800 group-hover:text-brand-600 transition-colors">
          Christine Burke Yoga
        </span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="px-3 py-2 text-sm font-medium text-gray-700 hover:text-brand-600 rounded-lg hover:bg-brand-50 transition-colors"
          >
            {link.label}
          </a>
        ))}
        <a
          href={`${base}contact/`}
          class="ml-3 px-5 py-2.5 text-sm font-semibold text-white bg-sage-600 hover:bg-sage-700 rounded-full transition-colors shadow-sm"
        >
          Contact
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-gray-700 hover:text-brand-600 rounded-lg hover:bg-brand-50"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
      >
        <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4">
      <div class="flex flex-col gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="px-4 py-3 text-base font-medium text-gray-700 hover:text-brand-600 rounded-lg hover:bg-brand-50 transition-colors"
          >
            {link.label}
          </a>
        ))}
        <a
          href={`${base}contact/`}
          class="mt-2 mx-4 px-5 py-3 text-center text-base font-semibold text-white bg-sage-600 hover:bg-sage-700 rounded-full transition-colors"
        >
          Contact
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });
</script>
