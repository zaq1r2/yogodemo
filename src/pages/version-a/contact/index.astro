---
import BaseLayout from '../../../version-a/layouts/BaseLayout.astro';
import site from '../../../content/site.json';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Contact" description="Get in touch with Christine Burke for private sessions, workshops, teacher training, and more.">
  <!-- Hero -->
  <section class="bg-brand-50 py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-serif font-bold text-brand-900">Get in Touch</h1>
      <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
        Ready to start your journey? Christine would love to hear from you.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Contact Info -->
        <div>
          <h2 class="text-2xl font-serif font-bold text-brand-900 mb-6">Contact Information</h2>

          <!-- Email -->
          <div class="flex items-start gap-4 mb-6">
            <div class="w-10 h-10 bg-sage-50 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-brand-800">Email</h3>
              <a href={`mailto:${site.email}`} class="text-sage-600 hover:text-sage-700 font-medium">
                {site.email}
              </a>
            </div>
          </div>

          <!-- Location -->
          <div class="flex items-start gap-4 mb-6">
            <div class="w-10 h-10 bg-sage-50 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-brand-800">Location</h3>
              <p class="text-gray-600">Los Angeles, California</p>
              <p class="text-sm text-gray-500">Online classes via Zoom + pop-up locations</p>
            </div>
          </div>

          <!-- Social Links -->
          <div class="mt-8">
            <h3 class="font-semibold text-brand-800 mb-4">Follow Christine</h3>
            <div class="flex gap-4">
              {site.socials.instagram && (
                <a href={site.socials.instagram} target="_blank" rel="noopener" class="flex items-center gap-2 px-4 py-2.5 bg-brand-50 hover:bg-brand-100 rounded-xl transition-colors text-brand-800">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                  <span class="text-sm font-medium">Instagram</span>
                </a>
              )}
              {site.socials.facebook && (
                <a href={site.socials.facebook} target="_blank" rel="noopener" class="flex items-center gap-2 px-4 py-2.5 bg-brand-50 hover:bg-brand-100 rounded-xl transition-colors text-brand-800">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                  <span class="text-sm font-medium">Facebook</span>
                </a>
              )}
              {site.socials.youtube && (
                <a href={site.socials.youtube} target="_blank" rel="noopener" class="flex items-center gap-2 px-4 py-2.5 bg-brand-50 hover:bg-brand-100 rounded-xl transition-colors text-brand-800">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                  <span class="text-sm font-medium">YouTube</span>
                </a>
              )}
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-serif font-bold text-brand-900 mb-6">Send a Message</h2>
          <form action={`https://formspree.io/f/placeholder`} method="POST" class="space-y-5">
            <p class="text-sm text-gray-500 bg-brand-50 p-3 rounded-lg">
              This form uses <a href="https://formspree.io" target="_blank" rel="noopener" class="underline">Formspree</a> (third-party). Alternatively, email Christine directly at <a href={`mailto:${site.email}`} class="font-medium text-sage-600">{site.email}</a>.
            </p>
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-sage-400 focus:border-transparent"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-sage-400 focus:border-transparent"
              />
            </div>
            <div>
              <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">Subject</label>
              <select
                id="subject"
                name="subject"
                class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-sage-400 focus:border-transparent"
              >
                <option>Private Sessions</option>
                <option>Classes</option>
                <option>Teacher Training</option>
                <option>Retreats & Events</option>
                <option>Corporate/Schools</option>
                <option>Press/Media</option>
                <option>Other</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-sage-400 focus:border-transparent resize-y"
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full px-8 py-3.5 bg-sage-600 hover:bg-sage-700 text-white font-semibold rounded-full transition-colors shadow-sm"
            >
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
