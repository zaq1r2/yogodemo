---
import BaseLayout from '../../layouts/BaseLayout.astro';
import programs from '../../content/programs.json';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Programs" description="Explore Christine Burke's transformative yoga programs: The Spiritual Mental Health Diet, Teacher Training, Retreats & Events.">
  <!-- Hero -->
  <section class="bg-brand-50 py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-serif font-bold text-brand-900">Programs</h1>
      <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
        Deepen your practice with Christine's signature programs and transformative experiences.
      </p>
    </div>
  </section>

  <!-- Programs -->
  {programs.map((program, i) => (
    <section id={program.id} class={`py-20 ${i % 2 === 0 ? 'bg-white' : 'bg-brand-50'}`}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class={`grid lg:grid-cols-2 gap-12 items-center ${i % 2 !== 0 ? 'lg:[direction:rtl] lg:[&>*]:[direction:ltr]' : ''}`}>
          <div>
            <span class="inline-block text-xs font-semibold text-sage-600 uppercase tracking-wider mb-2">{program.subtitle}</span>
            <h2 class="text-3xl font-serif font-bold text-brand-900 mb-4">{program.title}</h2>
            <p class="text-gray-600 leading-relaxed mb-6">{program.description}</p>
            <ul class="space-y-2 mb-8">
              {program.features.map((f: string) => (
                <li class="flex items-start gap-2 text-sm text-gray-600">
                  <svg class="w-5 h-5 text-sage-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <a
              href={program.ctaUrl.startsWith('/') ? `${base}${program.ctaUrl.slice(1)}` : program.ctaUrl}
              class="inline-flex px-8 py-3.5 bg-sage-600 hover:bg-sage-700 text-white font-semibold rounded-full transition-colors shadow-sm"
            >
              {program.cta}
            </a>
          </div>
          <img
            src={`${base}${program.image.replace(/^\//, '')}`}
            alt={program.title}
            class="rounded-2xl shadow-lg w-full max-w-md mx-auto object-cover aspect-[4/3]"
            loading="lazy"
          />
        </div>
      </div>
    </section>
  ))}

  <!-- SMHD Testimonials -->
  <section class="py-20 bg-sage-50" aria-labelledby="testimonials-heading">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="testimonials-heading" class="text-3xl font-serif font-bold text-brand-900 text-center mb-12">What Students Say</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <blockquote class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
          <p class="text-gray-600 leading-relaxed italic mb-4">
            "Christine really has changed my life. She has given me tools to center myself, relax and live a life full of happiness. The practices Christine teaches are not only easy but they WORK. They have helped me to lead a more wholesome life full of inner peace and clarity."
          </p>
          <cite class="text-sm font-semibold text-brand-800 not-italic">— Jessica B.</cite>
        </blockquote>
        <blockquote class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
          <p class="text-gray-600 leading-relaxed italic mb-4">
            "Christine's program and guidance are priceless. Through her vast modalities, I was guided to create a spiritual practice of my own. She helped to move me from my everyday survival stress to a calmer, happier and more grounded place."
          </p>
          <cite class="text-sm font-semibold text-brand-800 not-italic">— Jenny Eakes, 2019</cite>
        </blockquote>
        <blockquote class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
          <p class="text-gray-600 leading-relaxed italic mb-4">
            "This fantastic program provides a much deeper process than a traditional diet. This is about understanding what you are feeding — the key is to feed a positive and life affirming relationship with your life. This mind/body approach is transformative in a way that leaves a lasting impact."
          </p>
          <cite class="text-sm font-semibold text-brand-800 not-italic">— Student Review</cite>
        </blockquote>
        <blockquote class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
          <p class="text-gray-600 leading-relaxed italic mb-4">
            "The Spiritual Mental Health Diet has taught me the value in releasing negative thoughts that cause limitations. The program has truly fulfilled and inspired me. I am now able to realize what is essential to my spiritual growth and bring that to the forefront. It's a beautiful thing."
          </p>
          <cite class="text-sm font-semibold text-brand-800 not-italic">— Karen M., 2019</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- Source -->
  <div class="py-4 text-center">
    <p class="text-xs text-gray-400">
      Content sourced from
      <a href="https://www.christineburkeyoga.com/online-course" class="underline hover:text-gray-600" target="_blank" rel="noopener">christineburkeyoga.com</a>
    </p>
  </div>
</BaseLayout>
