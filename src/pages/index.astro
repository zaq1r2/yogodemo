---
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Christine Burke Yoga — Demo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&display=swap" rel="stylesheet" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'Inter', system-ui, sans-serif;
        background: #fbfaf7;
        color: #1a1a1a;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        text-align: center;
      }
      h1 {
        font-size: clamp(2rem, 4vw, 3.5rem);
        font-weight: 400;
        letter-spacing: -0.02em;
        line-height: 1.1;
        margin-bottom: 0.75rem;
      }
      .subtitle {
        color: #8a8a86;
        font-size: 1.0625rem;
        margin-bottom: 3rem;
      }
      .label {
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: #8a8a86;
        margin-bottom: 2rem;
      }
      .versions {
        display: flex;
        gap: 2rem;
        flex-wrap: wrap;
        justify-content: center;
      }
      a.version {
        display: block;
        border: 1px solid #e5e4e0;
        padding: 2.5rem 3rem;
        text-decoration: none;
        color: inherit;
        min-width: 240px;
        transition: border-color 0.2s, background 0.2s;
      }
      a.version:hover {
        border-color: #1a1a1a;
        background: #fff;
      }
      a.version h2 {
        font-size: 1.25rem;
        font-weight: 500;
        margin-bottom: 0.5rem;
      }
      a.version p {
        font-size: 0.875rem;
        color: #8a8a86;
        line-height: 1.5;
      }
      footer {
        margin-top: 4rem;
        font-size: 0.75rem;
        color: #8a8a86;
      }
    </style>
  </head>
  <body>
    <h1>Christine Burke Yoga</h1>
    <p class="subtitle">Demo Site</p>
    <p class="label">Choose a version</p>
    <div class="versions">
      <a href={`${base}version-a/`} class="version">
        <h2>Version A</h2>
        <p>Wellness editorial design.<br />Warm tones, rounded cards, sage accents.</p>
      </a>
      <a href={`${base}version-b/`} class="version">
        <h2>Version B</h2>
        <p>Minimal, text-first design.<br />Inspired by Gr&aacute; — print-editorial, typographic.</p>
      </a>
    </div>
    <footer>&copy; {new Date().getFullYear()} Demo</footer>
  </body>
</html>
