---
import BaseLayout from '../../version-b/layouts/BaseLayout.astro';
import EyebrowLabel from '../../version-b/components/EyebrowLabel.astro';
import EditorialList from '../../version-b/components/EditorialList.astro';
import Button from '../../version-b/components/Button.astro';
import Section from '../../version-b/components/Section.astro';
import site from '../../content/site.json';
import events from '../../content/events.json';
import books from '../../content/books.json';

const base = import.meta.env.BASE_URL;
const vb = `${base}version-b/`;
const now = new Date().toISOString().split('T')[0];
const upcoming = events
  .filter((e) => e.date >= now)
  .sort((a, b) => a.date.localeCompare(b.date))
  .slice(0, 3);

const upcomingItems = upcoming.map((e) => {
  const d = new Date(e.date + 'T00:00:00');
  return {
    title: e.title,
    meta: d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) + ' · ' + e.location,
    description: e.description,
    href: `${vb}events/`,
  };
});

const workItems = [
  {
    title: 'Private Sessions',
    meta: 'Online + In-person',
    description: 'A holistic, transformative approach — explore the vision you hold for your life using yoga philosophy for greater health, clarity, and vitality.',
  },
  {
    title: 'Classes & Workshops',
    meta: 'Zoom + Pop-up locations',
    description: 'From dynamic Morning Magic flows to candlelit Vinyasa — breath, meditation, and mindful movement to set you up for your best day.',
  },
  {
    title: 'Teacher Training',
    meta: '200-Hour Certification',
    description: 'A deep immersion into Hatha yoga covering philosophy, breath, sequencing, anatomy, therapeutics, and the art of teaching.',
  },
];
---

<BaseLayout title="Home" description="Christine Burke Yoga — Yoga, Breathwork & Holistic Wellness.">
  <!-- Hero -->
  <section class="content-col pt-space-6 pb-space-5 text-center">
    <h1 class="mb-6">Christine Burke</h1>
    <p class="text-lg text-muted max-w-[50ch] mx-auto mb-8">
      Yoga, breathwork & holistic wellness.<br />
      Online + in-person (pop-ups) · Los Angeles
    </p>
    <div class="flex justify-center gap-6 text-sm">
      <Button href={`${vb}work-with-christine/`} variant="outline">Work with Christine</Button>
      <Button href={`${vb}programs/`} variant="text">Explore Programs &rarr;</Button>
    </div>
  </section>

  <hr class="rule content-col" />

  <!-- Work with Christine -->
  <Section>
    <EyebrowLabel text="Work with Christine" class="mb-space-3" />
    <EditorialList items={workItems} />
    <div class="mt-space-3">
      <Button href={`${vb}work-with-christine/`} variant="text">View all offerings &rarr;</Button>
    </div>
  </Section>

  <hr class="rule content-col" />

  <!-- Upcoming -->
  {upcoming.length > 0 && (
    <>
      <Section>
        <EyebrowLabel text="Upcoming" class="mb-space-3" />
        <EditorialList items={upcomingItems} />
        <div class="mt-space-3">
          <Button href={`${vb}events/`} variant="text">All events &rarr;</Button>
        </div>
      </Section>
      <hr class="rule content-col" />
    </>
  )}

  <!-- Books -->
  <Section>
    <EyebrowLabel text="Published Works" class="mb-space-3" />
    <div class="grid grid-cols-3 gap-6 max-w-lg">
      {books.map((book) => (
        <div class="text-center">
          <img
            src={`${base}${book.image.replace(/^\//, '')}`}
            alt={book.title}
            class="w-full aspect-[3/4] object-cover mb-2"
            loading="lazy"
          />
          <p class="text-xs text-muted leading-tight">{book.title}</p>
        </div>
      ))}
    </div>
    <div class="mt-space-3">
      <Button href={`${vb}books-press/`} variant="text">Books & Press &rarr;</Button>
    </div>
  </Section>

  <hr class="rule content-col" />

  <!-- About -->
  <Section>
    <div class="grid md:grid-cols-[1fr_auto] gap-space-4 items-start">
      <div>
        <EyebrowLabel text="About" class="mb-space-2" />
        <p class="mb-4">
          Christine is the co-owner of Liberation Yoga and author of <em>The Yoga Healer</em>. Throughout her life she has been searching, and has always felt most comfortable, when asking the big questions of life while fully immersed in the small moments of existence.
        </p>
        <p class="text-muted text-sm mb-space-3">
          E-RYT 500+ · 25+ years teaching · 3 published books
        </p>
        <Button href={`${vb}about/`} variant="text">Full bio &rarr;</Button>
      </div>
      <img
        src={`${base}assets/ingested/christine-portrait.jpg`}
        alt="Christine Burke"
        class="w-48 lg:w-56 object-cover aspect-[3/4]"
        loading="lazy"
      />
    </div>
  </Section>

  <hr class="rule content-col" />

  <!-- Newsletter -->
  <section class="content-col py-space-5 text-center">
    <EyebrowLabel text="Stay in Your Light" class="mb-space-2" />
    <p class="text-muted text-sm max-w-[45ch] mx-auto mb-6">
      Community newsletter for class updates, wellness tips, and event announcements.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 max-w-sm mx-auto">
      <input
        type="email"
        placeholder="Email address"
        disabled
        aria-label="Email (placeholder)"
        class="flex-1 px-4 py-2.5 text-sm bg-transparent border border-border rounded-none focus:outline-none focus:border-fg"
      />
      <button disabled class="px-5 py-2.5 text-sm border border-fg text-fg bg-transparent cursor-not-allowed">
        Subscribe
      </button>
    </div>
    <p class="text-xs text-muted mt-2">Coming soon</p>
  </section>
</BaseLayout>
