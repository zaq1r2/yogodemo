---
import BaseLayout from '../../version-b/layouts/BaseLayout.astro';
import EyebrowLabel from '../../version-b/components/EyebrowLabel.astro';
import EditorialList from '../../version-b/components/EditorialList.astro';
import Section from '../../version-b/components/Section.astro';
import site from '../../content/site.json';
import events from '../../content/events.json';
import books from '../../content/books.json';

const base = import.meta.env.BASE_URL;
const vb = `${base}version-b/`;
const now = new Date().toISOString().split('T')[0];
const upcoming = events
  .filter((e) => e.date >= now)
  .sort((a, b) => a.date.localeCompare(b.date))
  .slice(0, 3);

const upcomingItems = upcoming.map((e) => {
  const d = new Date(e.date + 'T00:00:00');
  return {
    title: e.title,
    meta: d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) + '  ·  ' + e.location,
    description: e.description,
    href: `${vb}events/`,
  };
});

const workItems = [
  {
    title: 'Private Sessions',
    meta: 'Online + In-person',
    description: 'A holistic, transformative approach — explore the vision you hold for your life using yoga philosophy for greater health, clarity, and vitality.',
  },
  {
    title: 'Classes & Workshops',
    meta: 'Zoom + Pop-up locations',
    description: 'From dynamic Morning Magic flows to candlelit Vinyasa — breath, meditation, and mindful movement to set you up for your best day.',
  },
  {
    title: 'Teacher Training',
    meta: '200-Hour Certification',
    description: 'A deep immersion into Hatha yoga covering philosophy, breath, sequencing, anatomy, therapeutics, and the art of teaching.',
  },
];
---

<BaseLayout title="Home" description="Christine Burke Yoga — Yoga, Breathwork & Holistic Wellness.">
  <!-- HERO — Grá style: full viewport, asymmetric, art-directed -->
  <section class="min-h-screen relative flex flex-col justify-end overflow-hidden">
    <!-- Large hero image — center stage like Grá artwork -->
    <div class="absolute inset-0 flex items-center justify-center px-[30%] md:px-[20%] pt-16">
      <img
        src={`${base}assets/ingested/christine-1.jpg`}
        alt="Christine Burke"
        class="w-full max-w-2xl h-auto object-cover mix-blend-multiply opacity-90"
        loading="eager"
      />
    </div>

    <!-- Brand name — large serif, bottom-left like Grá -->
    <div class="relative z-10 page-pad pb-8">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8">
        <div>
          <h1 class="display text-[clamp(4rem,10vw,9rem)] leading-[0.9] tracking-tight">
            christine<br />burke
          </h1>
        </div>
        <div class="text-right md:pb-2">
          <p class="text-sm text-muted">Los Angeles</p>
          <p class="text-sm text-muted">Online + In-person (pop-ups)</p>
        </div>
      </div>
    </div>

    <!-- Descriptor — bottom, small, selective caps like Grá -->
    <div class="relative z-10 page-pad pb-12 pt-6">
      <p class="text-sm text-muted">
        Yoga, <span class="uppercase">breathwork</span> & holistic wellness,<br />
        <span class="uppercase">teacher training</span> and the <span class="uppercase">spiritual mental health diet</span>
      </p>
    </div>
  </section>

  <!-- WORK WITH CHRISTINE — editorial list, left-aligned -->
  <section class="container-wide py-space-6">
    <div class="max-w-3xl">
      <EyebrowLabel text="Work with Christine" class="mb-space-3" />
      <EditorialList items={workItems} />
      <div class="mt-space-4">
        <a href={`${vb}work-with-christine/`} class="nav-link hover-underline">View all offerings</a>
      </div>
    </div>
  </section>

  <!-- UPCOMING — editorial list -->
  {upcoming.length > 0 && (
    <section class="container-wide py-space-6">
      <div class="max-w-3xl">
        <EyebrowLabel text="Upcoming" class="mb-space-3" />
        <EditorialList items={upcomingItems} />
        <div class="mt-space-4">
          <a href={`${vb}events/`} class="nav-link hover-underline">All events</a>
        </div>
      </div>
    </section>
  )}

  <!-- BOOKS — minimal strip -->
  <section class="container-wide py-space-6">
    <div class="max-w-3xl">
      <EyebrowLabel text="Published Works" class="mb-space-3" />
      <div class="flex gap-8">
        {books.map((book) => (
          <div>
            <img
              src={`${base}${book.image.replace(/^\//, '')}`}
              alt={book.title}
              class="w-28 md:w-36 aspect-[3/4] object-cover"
              loading="lazy"
            />
            <p class="text-xs text-muted mt-2 max-w-[12ch]">{book.title}</p>
          </div>
        ))}
      </div>
      <div class="mt-space-4">
        <a href={`${vb}books-press/`} class="nav-link hover-underline">Books & Press</a>
      </div>
    </div>
  </section>

  <!-- ABOUT — asymmetric with image -->
  <section class="container-wide py-space-6">
    <div class="grid md:grid-cols-[1fr_auto] gap-space-4 items-start max-w-3xl">
      <div>
        <EyebrowLabel text="About" class="mb-space-2" />
        <p class="text-muted mb-4 max-w-[50ch]">
          Christine is the co-owner of Liberation Yoga and author of <em class="text-fg">The Yoga Healer</em>. Throughout her life she has been searching, and has always felt most comfortable, when asking the big questions of life while fully immersed in the small moments of existence.
        </p>
        <p class="text-xs text-muted mb-space-3">
          E-RYT 500+ &nbsp;&middot;&nbsp; 25+ years teaching &nbsp;&middot;&nbsp; 3 published books
        </p>
        <a href={`${vb}about/`} class="nav-link hover-underline">Full bio</a>
      </div>
      <img
        src={`${base}assets/ingested/christine-portrait.jpg`}
        alt="Christine Burke"
        class="w-44 lg:w-52 object-cover aspect-[3/4]"
        loading="lazy"
      />
    </div>
  </section>

  <!-- NEWSLETTER — minimal -->
  <section class="container-wide py-space-6 pb-space-5">
    <div class="max-w-3xl">
      <EyebrowLabel text="Newsletter" class="mb-space-2" />
      <p class="text-muted text-sm mb-6 max-w-[40ch]">
        Community updates, wellness tips, and event announcements.
      </p>
      <p class="text-xs text-muted">Coming soon</p>
    </div>
  </section>
</BaseLayout>
